    <title>单路分发和多路分发</title>
    <link href="http://example.com/2025/01/21/Java-%E5%8D%95%E8%B7%AF%E5%88%86%E5%8F%91%E5%92%8C%E5%A4%9A%E8%B7%AF%E5%88%86%E5%8F%91/"/>
    <id>http://example.com/2025/01/21/Java-%E5%8D%95%E8%B7%AF%E5%88%86%E5%8F%91%E5%92%8C%E5%A4%9A%E8%B7%AF%E5%88%86%E5%8F%91/</id>
    <published>2025-01-21T06:24:57.000Z</published>
